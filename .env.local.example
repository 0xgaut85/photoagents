# Privy auth (https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# Postgres (Railway provides DATABASE_URL automatically inside the service)
DATABASE_URL=postgresql://user:pass@host:5432/db

# Your Base wallet address that receives USDC from buyers.
# (Configured on the Helio paylink itself; kept here so the UI can display it.)
NEXT_PUBLIC_PAYMENT_WALLET_ADDRESS=0xYourBaseWallet

# Helio / MoonPay Commerce — embed widget mode (https://app.hel.io)
# The paylink id of your $15 plan. Found in the paylink URL or detail page.
NEXT_PUBLIC_HELIO_PAYLINK_ID=69f31b29a06de540a18db767
# Shared token you set when creating the webhook. Used for both
# `Authorization: Bearer <token>` and as the HMAC-SHA256 key for X-Signature.
HELIO_WEBHOOK_SHARED_TOKEN=replace_with_long_random_string
