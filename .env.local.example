# Privy auth (https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# Postgres (Railway provides DATABASE_URL automatically inside the service)
DATABASE_URL=postgresql://user:pass@host:5432/db

# Coinbase Commerce (https://commerce.coinbase.com -> Settings)
COINBASE_COMMERCE_API_KEY=your_commerce_api_key
COINBASE_COMMERCE_WEBHOOK_SECRET=your_commerce_webhook_secret

# Coinbase Onramp (https://portal.cdp.coinbase.com)
NEXT_PUBLIC_COINBASE_ONRAMP_APP_ID=

# Your Base USDC receiving wallet (the address that gets paid)
NEXT_PUBLIC_PAYMENT_WALLET_ADDRESS=
